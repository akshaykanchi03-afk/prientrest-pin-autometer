# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# PINTEREST_CLIENT_ID: Your Pinterest Developer Application Client ID (App ID)
PINTEREST_CLIENT_ID=your_pinterest_client_id

# PINTEREST_CLIENT_SECRET: Your Pinterest Developer Application Client Secret
PINTEREST_CLIENT_SECRET=your_pinterest_client_secret

# PINTEREST_REDIRECT_URI: Your registered Redirect URI (e.g., https://localhost/auth/pinterest or myapp://pinterest)
PINTEREST_REDIRECT_URI=https://localhost/auth/pinterest

